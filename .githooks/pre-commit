#!/bin/sh
# Git Hook: pre-commit (Strict & Friendly)

FILES=$(git diff --cached --name-only --diff-filter=AMCR | grep -E '\.(php|blade\.php)$')

if [ -z "$FILES" ]; then
    exit 0
fi

echo "--- 🛠️ Laravel Pint による自動整形を開始 ---"

# 1. Sailの起動確認
if ! ./vendor/bin/sail ps > /dev/null 2>&1; then
    echo "❌ [中止] Sail (Docker) が起動していません。"
    echo "   → './vendor/bin/sail up -d' で起動してから再度コミットしてください。"
    exit 1
fi

# 2. Pintの実行
FILENAMES=$(echo "$FILES" | xargs)
# 出力を一時保存してエラー解析に使う
PINT_OUTPUT=$(./vendor/bin/sail php ./vendor/bin/pint $FILENAMES 2>&1)
PINT_RESULT=$?

# 3. エラー判定とメッセージ出力
if [ $PINT_RESULT -ne 0 ]; then
    echo "$PINT_OUTPUT" # 実際の詳細エラーを表示
    echo "---------------------------------------------------------"
    echo "❌ [失敗] Pintによる整形を完了できませんでした。"
    "---------------------------------------------------------"
    exit 1
fi

# 4. 成功時の処理
echo "--- ✨ 整形完了。変更をステージングに追加 ---"
echo "$FILES" | xargs git add
echo "✅ すべてのチェックを通過しました！"
exit 0
